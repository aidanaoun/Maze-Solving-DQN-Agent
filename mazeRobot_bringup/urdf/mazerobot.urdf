<?xml version="1.0"?>
<robot name="maze_robot">

  <link name="chassis">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.113" ixy="0.0" ixz="0.0" iyy="0.033" iyz="0.0" izz="0.133"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.4 0.8 0.2"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="purple">
        <color rgba="0 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.43 0.83 0.2"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <link name="left_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <link name="front_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <link name="right_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>


  <link name="back_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>


  <link name="frontleft_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <link name="frontright_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <link name="backleft_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <link name="backright_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>

  <link name="rightWheel">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.00250" iyy="0.00132" izz="0.00132" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 -1.5707963268 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5707963268 0"/>
      

<surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>1.5</mu2>
        </ode>
      </friction>
    </surface>

    </collision>
  </link>

  <link name="leftWheel">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.00250" ixy="0.0" ixz="0.0" iyy="0.00132" iyz="0.0" izz="0.00132"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>

<surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>1.5</mu2>
          <slip1>0.05</slip1>
          <slip2>0.05</slip2>
        </ode>
      </friction>
    </surface>

    </collision>
  </link>

  <link name="frontWheel">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>

<surface>
      <friction>
        <ode>
          <mu>0.0000000001</mu>
          <mu2>0.0000000001</mu2>
          <slip1>0.05</slip1>
          <slip2>0.05</slip2>
        </ode>
      </friction>
    </surface>

    </collision>
  </link>

  <joint name="chassis_to_rightWheel" type="continuous">
    <parent link="chassis"/>
    <child link="rightWheel"/>
    <origin xyz="0.22 -0.2 -0.15" rpy="0 0 0"/>
    <axis xyz="1 0 0">
        <dynamics damping="0.05"/>
    </axis>
  </joint>

  <joint name="chassis_to_leftWheel" type="continuous">
    <parent link="chassis"/>
    <child link="leftWheel"/>
    <origin xyz="-0.22 -0.2 -0.15" rpy="0 0 0"/>
    <axis xyz="1 0 0">
        <dynamics damping="0.05"/>
    </axis>
  </joint>

  <joint name="chassis_to_frontWheel" type="fixed">
    <parent link="chassis"/>
    <child link="frontWheel"/>
    <origin xyz="0 0.35 -0.15" rpy="0 0 0"/>
  </joint>

  <joint name="left_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="left_sensor"/>
    <origin xyz="-0.2125 0.1 0.1" rpy="0 0 3.14159"/>
  </joint>

  <joint name="right_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="right_sensor"/>
    <origin xyz="0.2125 0.1 0.1" rpy="0 0 0"/>
  </joint>

  <joint name="front_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="front_sensor"/>
    <origin xyz="0 0.4125 0.1" rpy="0 0 1.5707"/>
  </joint>

  <joint name="back_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="back_sensor"/>
    <origin xyz="0 -0.4125 0.1" rpy="0 0 -1.5707"/>
  </joint>

<joint name="frontleft_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="frontleft_sensor"/>
    <origin xyz="-0.2125 0.4125 0.1" rpy="0 0 2.35609"/>
  </joint>

<joint name="frontright_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="frontright_sensor"/>
    <origin xyz="0.2125 0.4125 0.1" rpy="0 0 0.785398"/>
  </joint>

<joint name="backleft_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="backleft_sensor"/>
    <origin xyz="-0.2125 -0.4125 0.1" rpy="0 0 -2.35609"/>
  </joint>

<joint name="backright_sensor_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="backright_sensor"/>
    <origin xyz="0.2125 -0.4125 0.1" rpy="0 0 -0.785398"/>
  </joint>


<!-- Right lidar mounted on link 'right_sensor' -->
<gazebo reference="right_sensor">
  <sensor type="gpu_lidar" name="right_lidar">
    <pose>0 0 0 0 0 0</pose>
    <update_rate>15</update_rate>
    <visualize>true</visualize>
    <lidar>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
          <min_angle>-0.0001</min_angle>
          <max_angle>0.0001</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.02</min>
        <max>35.0</max>
        <resolution>0.01</resolution>
      </range>
    </lidar>
    <topic>scan_right</topic>
    <gz_frame_id>right_sensor</gz_frame_id>
  </sensor>
</gazebo>

<!-- Left lidar -->
<gazebo reference="left_sensor">
  <sensor type="gpu_lidar" name="left_lidar">
    <pose>0 0 0 0 0 0</pose>
    <update_rate>15</update_rate>
    <visualize>true</visualize>
    <lidar>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
